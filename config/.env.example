# Environment Variables for QNet
# Copy this file to .env and customize as needed

# Simulation Settings
QNET_NODE_COUNT=100
QNET_DURATION=60
QNET_SEED=42

# Database Settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qnet
POSTGRES_USER=qnet
POSTGRES_PASSWORD=qnet_secret

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
WS_PORT=8001

# Security
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=false

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8001
